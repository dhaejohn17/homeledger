// HomeLedger — PostgreSQL schema
// Run `npm run db:push` to sync, then `npm run db:seed` to load demo data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users & auth
// ---------------------------------------------------------------------------
model User {
  id           String         @id @default(uuid())
  name         String?
  email        String         @unique
  passwordHash String?
  image        String?
  role         SystemRole     @default(USER)
  createdAt    DateTime       @default(now())

  ownedWallets Wallet[]       @relation("WalletOwner")
  memberships  WalletMember[]
  debtsOwed    Debt[]         @relation("Debtor")
  debtsLent    Debt[]         @relation("Creditor")
}

enum SystemRole {
  USER
  ADMIN
}

// ---------------------------------------------------------------------------
// Wallets — a personal or shared container for accounts, categories, budgets
// ---------------------------------------------------------------------------
model Wallet {
  id          String         @id @default(uuid())
  name        String
  description String?
  type        WalletType     @default(PERSONAL)
  inviteCode  String?        @unique
  createdAt   DateTime       @default(now())

  ownerId     String
  owner       User           @relation("WalletOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     WalletMember[]
  accounts    Account[]
  categories  Category[]
  budgets     Budget[]
  goals       SavingsGoal[]

  @@index([ownerId])
}

enum WalletType {
  PERSONAL
  SHARED
}

model WalletMember {
  id       String     @id @default(uuid())
  walletId String
  userId   String
  role     WalletRole @default(MEMBER)
  joinedAt DateTime   @default(now())

  wallet   Wallet     @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([walletId, userId])
}

enum WalletRole {
  OWNER
  ADMIN
  MEMBER
}

// ---------------------------------------------------------------------------
// Money
// ---------------------------------------------------------------------------
model Account {
  id           String        @id @default(uuid())
  walletId     String
  name         String
  type         AccountType
  balance      Float         @default(0)
  currency     String        @default("PHP")
  createdAt    DateTime      @default(now())

  wallet       Wallet        @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([walletId])
}

enum AccountType {
  CASH
  BANK
  EWALLET
  CREDIT_CARD
  SAVINGS
}

model Category {
  id           String          @id @default(uuid())
  walletId     String?
  name         String
  icon         String?
  color        String?
  type         TransactionType

  wallet       Wallet?         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@index([walletId])
}

model Transaction {
  id           String          @id @default(uuid())
  accountId    String
  categoryId   String?
  amount       Float
  type         TransactionType
  description  String?
  date         DateTime        @default(now())
  isRecurring  Boolean         @default(false)
  recurrenceId String?
  createdAt    DateTime        @default(now())

  account      Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category     Category?       @relation(fields: [categoryId], references: [id])
  receipt      Receipt?

  @@index([accountId])
  @@index([categoryId])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

// ---------------------------------------------------------------------------
// Receipts (OCR pipeline)
// ---------------------------------------------------------------------------
model Receipt {
  id             String        @id @default(uuid())
  transactionId  String        @unique
  fileUrl        String
  merchantName   String?
  totalExtracted Float?
  rawOcrData     String?
  status         ReceiptStatus @default(PENDING)
  createdAt      DateTime      @default(now())

  transaction    Transaction   @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  items          ReceiptItem[]
}

model ReceiptItem {
  id          String  @id @default(uuid())
  receiptId   String
  description String
  quantity    Float   @default(1)
  price       Float

  receipt     Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
}

enum ReceiptStatus {
  PENDING
  REVIEWED
  AUTO_LOGGED
  FAILED
}

// ---------------------------------------------------------------------------
// Budgets, goals, debts
// ---------------------------------------------------------------------------
model Budget {
  id         String    @id @default(uuid())
  walletId   String
  categoryId String?
  amount     Float
  period     Period    @default(MONTHLY)

  wallet     Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  category   Category? @relation(fields: [categoryId], references: [id])

  @@index([walletId])
}

enum Period {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model SavingsGoal {
  id            String    @id @default(uuid())
  walletId      String
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?

  wallet        Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
}

model Debt {
  id           String     @id @default(uuid())
  amount       Float
  type         DebtType
  issueDate    DateTime   @default(now())
  dueDate      DateTime?
  status       DebtStatus @default(ACTIVE)

  creditorId   String?
  debtorId     String?
  externalName String?

  creditor     User?      @relation("Creditor", fields: [creditorId], references: [id])
  debtor       User?      @relation("Debtor", fields: [debtorId], references: [id])
}

enum DebtType {
  BORROWED
  LENT
}

enum DebtStatus {
  ACTIVE
  PAID
  OVERDUE
}
