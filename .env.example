# ---------------------------------------------------------------------------
# Database (matches the credentials in docker-compose.yml)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://homeledger:homeledger_password@localhost:5432/homeledger?schema=public"

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5) — generate a strong secret with:  npx auth secret
# ---------------------------------------------------------------------------
AUTH_SECRET="change-me-run-npx-auth-secret"
AUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Local AI (Ollama). Runs on the host; the app talks to it over HTTP.
# OLLAMA_MODEL must be a model you've pulled (run: ollama list).
# llama3:latest is the lightest/fastest of your installed models — a good default.
# For sharper answers at higher cost, switch to qwen3:14b.
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3:latest"
